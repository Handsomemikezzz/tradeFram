# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Backend
DATABASE_URL=sqlite:///./paper_trading.db
MARKET_DATA_PROVIDER=akshare
AKSHARE_ENABLED=true
DATA_CACHE_TTL_MINUTES=1440
ALLOW_MANUAL_RUN_OUTSIDE_TRADING_TIME=true
STRICT_TRADING_TIME_CHECK=false
AKSHARE_BYPASS_PROXY=true

# AkShare-only notes:
# - Install requirements.txt before using real data.
# - Tests use AkShare-shaped local fixtures; live smoke depends on external AkShare/upstream availability.
# - Local dev bypasses system proxy for Eastmoney by default because AkShare upstream calls may fail through local proxy tools.
# - Do not configure real brokerage credentials in this project.
