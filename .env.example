# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Backend
DATABASE_URL=sqlite:///./paper_trading.db
MARKET_DATA_PROVIDER=mock
AKSHARE_ENABLED=false
DATA_CACHE_TTL_MINUTES=1440
ALLOW_MANUAL_RUN_OUTSIDE_TRADING_TIME=true
STRICT_TRADING_TIME_CHECK=false

# v0.1 Beta notes:
# - mock is the default deterministic provider for local dev/tests.
# - akshare can be selected only after installing/configuring AkShare locally and setting AKSHARE_ENABLED=true.
# - Do not configure real brokerage credentials in this project.
